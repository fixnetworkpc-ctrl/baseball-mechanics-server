# Copy this to .env — NEVER commit .env to GitHub

# Anthropic API key
ANTHROPIC_KEY=sk-ant-api03-YOUR-KEY

# Gmail App Password for fixnetworkpc@gmail.com
# HOW TO GET IT:
# 1. Go to myaccount.google.com → Security
# 2. Enable 2-Step Verification if not already on
# 3. Search "App Passwords" → Generate
# 4. App: Mail, Device: Other ("Baseball Mechanics Server")
# 5. Copy the 16-character password (no spaces)
GMAIL_APP_PASSWORD=your16charpassword

# App secret — shared key between the mobile app and this server.
# Prevents unauthorized callers from using your Anthropic API credits.
# HOW TO GENERATE: run this in Terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Paste the output here AND into src/config.js APP_SECRET in the mobile app.
APP_SECRET=generate-a-random-64-char-hex-string-here

# Port (Render sets this automatically)
PORT=3001
