# Copy this to .env — NEVER commit .env to GitHub

# Anthropic API keys
ANTHROPIC_KEY_PITCHING=sk-ant-api03-YOUR-PITCHING-KEY
ANTHROPIC_KEY_BATTING=sk-ant-api03-YOUR-BATTING-KEY

# Gmail App Password for fixnetworkpc@gmail.com
# HOW TO GET IT:
# 1. Go to myaccount.google.com → Security
# 2. Enable 2-Step Verification if not already on
# 3. Search "App Passwords" → Generate
# 4. App: Mail, Device: Other ("Baseball Mechanics Server")
# 5. Copy the 16-character password (no spaces)
GMAIL_APP_PASSWORD=your16charpassword

# Port (Render sets this automatically)
PORT=3001
